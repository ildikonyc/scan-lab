{
  "expo": {
    "name": "Scan Lab",
    "slug": "scan-lab",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1714"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shelfscanner.scanlab",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan Lab needs camera access to photograph bookshelves"
      }
    },
    "android": {
      "package": "com.shelfscanner.scanlab",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1714"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Scan Lab needs camera access to photograph bookshelves"
        }
      ],
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "d925d867-90b5-4cc4-8887-0a8ad00e8c4b"
      }
    },
    "owner": "ildikodesign"
  }
}
